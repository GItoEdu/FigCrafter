<Window x:Class="FigCrafterApp.Views.ExportSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="エクスポート設定" Height="250" Width="320" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="形式:" Grid.Row="0" Grid.Column="0" Margin="5,10,10,10" VerticalAlignment="Center"/>
        <ComboBox x:Name="FormatComboBox" Grid.Row="0" Grid.Column="1" Margin="5" SelectedIndex="0">
            <ComboBoxItem Content="PNG画像 (*.png)" Tag=".png"/>
            <ComboBoxItem Content="PDFファイル (*.pdf)" Tag=".pdf"/>
            <ComboBoxItem Content="TIFF画像 (*.tif)" Tag=".tif"/>
        </ComboBox>

        <TextBlock Text="解像度(DPI):" Grid.Row="1" Grid.Column="0" Margin="5,10,10,10" VerticalAlignment="Center"/>
        <ComboBox x:Name="DpiComboBox" Grid.Row="1" Grid.Column="1" Margin="5" SelectedIndex="1">
            <ComboBoxItem Content="72" Tag="72"/>
            <ComboBoxItem Content="96 (標準)" Tag="96"/>
            <ComboBoxItem Content="144" Tag="144"/>
            <ComboBoxItem Content="300 (高画質)" Tag="300"/>
            <ComboBoxItem Content="600 (最高画質)" Tag="600"/>
        </ComboBox>

        <CheckBox x:Name="TransparentCheckBox" Content="背景を透過する（PNGのみ）" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="5,15,5,5" IsChecked="False"/>

        <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="OK" Width="80" Margin="5" Click="OkButton_Click" IsDefault="True"/>
            <Button Content="キャンセル" Width="80" Margin="5" Click="CancelButton_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>