<Window x:Class="FigCrafterApp.Views.PrintSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="印刷設定" Height="200" Width="300" 
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FF2D2D30" Foreground="White">
    <StackPanel Margin="20">
        <TextBlock Text="印刷倍率 (%)" Margin="0,0,0,10" FontSize="14"/>
        <DockPanel>
            <TextBox x:Name="ScaleTextBox" Width="60" Text="100" VerticalAlignment="Center" 
                     Background="#FF3E3E42" Foreground="White" BorderThickness="1" Padding="3"/>
            <Slider x:Name="ScaleSlider" Minimum="10" Maximum="500" Value="100" Margin="10,0,0,0"
                    IsSnapToTickEnabled="True" TickFrequency="1"/>
        </DockPanel>
        <CheckBox x:Name="AutoFitCheckBox" Content="用紙に合わせて自動調整" Foreground="White" Margin="0,15,0,0"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="印刷" Width="75" Click="Print_Click" IsDefault="True" Margin="0,0,10,0"
                    Background="#FF007ACC" Foreground="White" BorderThickness="0"/>
            <Button Content="キャンセル" Width="75" IsCancel="True"
                    Background="#FF3E3E42" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </StackPanel>
</Window>