<Window x:Class="FigCrafterApp.Views.ContrastDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="画像調整" Height="285" Width="420"
        Background="#FF2D2D30" Foreground="White"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.Resources>
            <Style TargetType="TextBlock" x:Key="LabelStyle">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
                <Setter Property="Foreground" Value="Gray"/>
                <Setter Property="Width" Value="70"/>
            </Style>
        </Grid.Resources>

        <TextBlock Text="コントラストと明るさの調整" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="コントラスト:" Style="{StaticResource LabelStyle}"/>
                <Slider x:Name="ContrastSlider" Grid.Column="1" 
                        Minimum="0.1" Maximum="3.0" 
                        Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}" 
                        SmallChange="0.01" LargeChange="0.1"
                        VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" Width="60" Text="{Binding Contrast, StringFormat=\{0:F2\}, UpdateSourceTrigger=LostFocus}" 
                         Background="#FF3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#FF555555"
                         Padding="3" Margin="10,0,0,0" VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
            </Grid>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="明るさ:" Style="{StaticResource LabelStyle}"/>
                <Slider Grid.Column="1" 
                        Minimum="-1.0" Maximum="1.0" 
                        Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}" 
                        SmallChange="0.01" LargeChange="0.1"
                        VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" Width="60" Text="{Binding Brightness, StringFormat=\{0:F2\}, UpdateSourceTrigger=LostFocus}" 
                         Background="#FF3E3E42" Foreground="White" BorderThickness="1" BorderBrush="#FF555555"
                         Padding="3" Margin="10,0,0,0" VerticalAlignment="Center" HorizontalContentAlignment="Center"/>
            </Grid>

            <TextBlock Text="※スライダーを動かすとキャンバスにリアルタイムで反映されます。" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="キャンセル" Click="CancelButton_Click" Width="80" Height="28" Margin="0,0,10,0" 
                    Background="#FF3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="適用" Click="ApplyButton_Click" Width="80" Height="28"
                    Background="#FF007ACC" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
