<Window x:Class="FigCrafterApp.Views.ContrastDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:FigCrafterApp.Views"
        Title="画像調整" Height="480" Width="420"
        Background="#FF2D2D30" Foreground="White"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.Resources>
            <Style TargetType="TextBlock" x:Key="LabelStyle">
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Margin" Value="0,0,10,0"/>
                <Setter Property="Foreground" Value="Gray"/>
                <Setter Property="Width" Value="80"/>
            </Style>

            <Style TargetType="TextBox" x:Key="TextBoxStyle">
                <Setter Property="Background" Value="#FF3E3E42"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="BorderBrush" Value="#FF555555"/>
                <Setter Property="Padding" Value="3"/>
                <Setter Property="Margin" Value="10,0,0,0"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
            </Style>
        </Grid.Resources>

        <TextBlock Text="画像調整" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <!-- Header for orientation -->
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="1" Text="輝度ヒストグラム" Foreground="Gray" FontSize="11" HorizontalAlignment="Center"/>
            </Grid>

            <!-- Aligned Histogram -->
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <views:HistogramView Grid.Column="1" HistogramData="{Binding IntensityHistogram}" Height="80"/>
            </Grid>
            
            <!-- Range Sliders (Min/Max) - Aligned with Histogram -->
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/></Grid.ColumnDefinitions>
                <TextBlock Text="Minimum:" Style="{StaticResource LabelStyle}"/>
                <Slider Grid.Column="1" Minimum="0.0" Maximum="1.0" Value="{Binding Minimum, UpdateSourceTrigger=PropertyChanged}" SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" Width="60" Text="{Binding Minimum, StringFormat=\{0:F2\}, UpdateSourceTrigger=LostFocus}" Style="{StaticResource TextBoxStyle}"/>
            </Grid>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/></Grid.ColumnDefinitions>
                <TextBlock Text="Maximum:" Style="{StaticResource LabelStyle}"/>
                <Slider Grid.Column="1" Minimum="0.0" Maximum="1.0" Value="{Binding Maximum, UpdateSourceTrigger=PropertyChanged}" SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" Width="60" Text="{Binding Maximum, StringFormat=\{0:F2\}, UpdateSourceTrigger=LostFocus}" Style="{StaticResource TextBoxStyle}"/>
            </Grid>

            <Separator Margin="0,0,0,15" Background="#FF3E3E42"/>
            <CheckBox Content="グレースケール" IsChecked="{Binding IsGrayscale, UpdateSourceTrigger=PropertyChanged}" Foreground="White" Margin="0,0,0,15" FontSize="11"/>
            <Separator Margin="0,0,0,15" Background="#FF3E3E42"/>

            <!-- Indirect Controls (Brightness/Contrast) -->
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/></Grid.ColumnDefinitions>
                <TextBlock Text="明るさ:" Style="{StaticResource LabelStyle}"/>
                <Slider Grid.Column="1" Minimum="-0.5" Maximum="0.5" Value="{Binding Brightness, UpdateSourceTrigger=PropertyChanged}" SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" Width="60" Text="{Binding Brightness, StringFormat=\{0:F2\}, UpdateSourceTrigger=LostFocus}" Style="{StaticResource TextBoxStyle}"/>
            </Grid>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions><ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="70"/></Grid.ColumnDefinitions>
                <TextBlock Text="コントラスト:" Style="{StaticResource LabelStyle}"/>
                <Slider Grid.Column="1" Minimum="0.1" Maximum="10.0" Value="{Binding Contrast, UpdateSourceTrigger=PropertyChanged}" SmallChange="0.01" LargeChange="0.1" VerticalAlignment="Center"/>
                <TextBox Grid.Column="2" Width="60" Text="{Binding Contrast, StringFormat=\{0:F2\}, UpdateSourceTrigger=LostFocus}" Style="{StaticResource TextBoxStyle}"/>
            </Grid>

            <TextBlock Text="※Min/Maxを調整するとヒストグラム上の表示範囲が変化します。" FontSize="10" Foreground="Gray" HorizontalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="キャンセル" Click="CancelButton_Click" Width="80" Height="28" Margin="0,0,10,0" 
                    Background="#FF3E3E42" Foreground="White" BorderThickness="0"/>
            <Button Content="適用" Click="ApplyButton_Click" Width="80" Height="28"
                    Background="#FF007ACC" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
