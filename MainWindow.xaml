<Window x:Class="FigCrafterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FigCrafterApp"
        xmlns:vm="clr-namespace:FigCrafterApp.ViewModels"
        xmlns:views="clr-namespace:FigCrafterApp.Views"
        xmlns:skia="clr-namespace:SkiaSharp;assembly=SkiaSharp"
        mc:Ignorable="d"
        Title="FigCrafter" Height="720" Width="1280"
        Background="#FF1E1E1E" Foreground="White"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <!-- Ctrl+N: 新規キャンバス -->
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewDocumentCommand}"/>
        <!-- Ctrl+S: 上書き保存 -->
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveProjectCommand}"/>
        <!-- Ctrl+Shift+S: 別名で保存 -->
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsProjectCommand}"/>
        <!-- Ctrl+O: 開く -->
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenProjectCommand}"/>
        <!-- Ctrl+Z: Undo -->
        <KeyBinding Key="Z" Modifiers="Control" Command="{Binding ActiveDocument.UndoCommand}"/>
        <!-- Ctrl+Y: Redo -->
        <KeyBinding Key="Y" Modifiers="Control" Command="{Binding ActiveDocument.RedoCommand}"/>
        <!-- Ctrl+Shift+C: 画像調整ダイアログ表示 -->
        <KeyBinding Key="C" Modifiers="Control+Shift" Command="{Binding ShowContrastDialogCommand}"/>
        <!-- Ctrl+0: ウィンドウに合わせる -->
        <KeyBinding Key="D0" Modifiers="Control" Command="{Binding ActiveDocument.ZoomToFitCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <local:EnumToBoolConverter x:Key="EnumToBoolConverter"/>
        <local:SKColorToSolidColorBrushConverter x:Key="SKColorToSolidColorBrushConverter"/>
        <local:LogZoomConverter x:Key="LogZoomConverter"/>
        <local:FontSizeConverter x:Key="FontSizeConverter"/>
        <!-- タブのスタイル定義（ダークモード用） -->
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="#FF2D2D30"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid x:Name="Panel">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="12,2,12,2" />
                            <Border x:Name="BottomBorder" Height="2" Background="Transparent" VerticalAlignment="Bottom"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Panel" Property="Background" Value="#FF3E3E42"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="BottomBorder" Property="Background" Value="#FF007ACC"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Panel" Property="Background" Value="#FF3E3E42"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolButtonStyle" TargetType="RadioButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
            <Setter Property="Background" Value="#FF3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#FF007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ToolActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3E3E42"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FF007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- メニューバー (0) -->
            <RowDefinition Height="Auto"/> <!-- 図形ツールバー (1) -->
            <RowDefinition Height="Auto"/> <!-- プロパティツールバー (2) -->
            <RowDefinition Height="*"/>    <!-- メインコンテンツ (3) -->
            <RowDefinition Height="Auto"/> <!-- ステータスバー (4) -->
        </Grid.RowDefinitions>

        <!-- Row 0: メニューバー -->
        <Menu Grid.Row="0" Background="{DynamicResource {x:Static SystemColors.MenuBrushKey}}" Foreground="{DynamicResource {x:Static SystemColors.MenuTextBrushKey}}">
            <Menu.Resources>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.MenuTextBrushKey}}"/>
                </Style>
            </Menu.Resources>
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="新規キャンバス (_N)" Command="{Binding NewDocumentCommand}" InputGestureText="Ctrl+N"/>
                <MenuItem Header="開く / インポート (_O)" Command="{Binding OpenProjectCommand}" InputGestureText="Ctrl+O"/>
                <Separator/>
                <MenuItem Header="上書き保存 (_S)" Command="{Binding SaveProjectCommand}" InputGestureText="Ctrl+S"/>
                <MenuItem Header="別名で保存..." Command="{Binding SaveAsProjectCommand}" InputGestureText="Ctrl+Shift+S"/>
                <Separator/>
                <MenuItem Header="エクスポート..." Command="{Binding ExportMixedCommand}"/>
            </MenuItem>
            <MenuItem Header="編集(_E)">
                <MenuItem Header="元に戻す (_Z)" Command="{Binding ActiveDocument.UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="やり直し (_Y)" Command="{Binding ActiveDocument.RedoCommand}" InputGestureText="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="切り取り (_X)" InputGestureText="Ctrl+X"/>
                <MenuItem Header="コピー (_C)" InputGestureText="Ctrl+C"/>
                <MenuItem Header="貼り付け (_V)" InputGestureText="Ctrl+V"/>
                <MenuItem Header="全選択 (_A)" InputGestureText="Ctrl+A"/>
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="スナップ切り替え" InputGestureText="Ctrl+U"/>
            </MenuItem>
        </Menu>

        <!-- Row 2: プロパティツールバー（オブジェクト選択時に表示） -->
        <Border Grid.Row="2" Background="#FF2D2D30" DataContext="{Binding ActiveDocument.SelectedObject}" MinHeight="32">
            <StackPanel Orientation="Horizontal" Margin="5,3">
                <!-- 座標・サイズ -->
                <TextBlock Text="X:" Foreground="Gray" VerticalAlignment="Center" Margin="5,0,2,0"/>
                <TextBox Text="{Binding X, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" Width="55" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="3,2" VerticalAlignment="Center"/>
                <TextBlock Text="Y:" Foreground="Gray" VerticalAlignment="Center" Margin="5,0,2,0"/>
                <TextBox Text="{Binding Y, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" Width="55" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="3,2" VerticalAlignment="Center"/>
                <TextBlock Text="W:" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,2,0"/>
                <TextBox Text="{Binding Width, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" Width="55" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="3,2" VerticalAlignment="Center"/>
                <TextBlock Text="H:" Foreground="Gray" VerticalAlignment="Center" Margin="5,0,2,0"/>
                <TextBox Text="{Binding Height, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" Width="55" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="3,2" VerticalAlignment="Center"/>
                <TextBlock Text="回転:" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,2,0"/>
                <TextBox Text="{Binding Rotation, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" Width="45" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="3,2" VerticalAlignment="Center"/>
                <TextBlock Text="°" Foreground="Gray" VerticalAlignment="Center" Margin="1,0,0,0"/>
                <TextBlock Text="不透明度:" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,2,0"/>
                <Slider Minimum="0" Maximum="1" Value="{Binding Opacity, UpdateSourceTrigger=PropertyChanged}" Width="60" VerticalAlignment="Center" Margin="0,0,5,0" SmallChange="0.05" LargeChange="0.1"/>
                <TextBox Text="{Binding Opacity, StringFormat=\{0:F2\}, UpdateSourceTrigger=PropertyChanged}" Width="40" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="3,2" VerticalAlignment="Center"/>

                <!-- セパレータ -->
                <Border Width="1" Background="#FF555555" Margin="8,2"/>

                <!-- 整列ボタン -->
                <Button Content="&#xE1AD;" FontFamily="Segoe Fluent Icons" ToolTip="左揃え" Command="{Binding DataContext.ActiveDocument.AlignLeftCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
                <Button Content="&#xF1CB;" FontFamily="Segoe Fluent Icons" ToolTip="水平中央揃え" Command="{Binding DataContext.ActiveDocument.AlignCenterHCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
                <Button Content="&#xE150;" FontFamily="Segoe Fluent Icons" ToolTip="右揃え" Command="{Binding DataContext.ActiveDocument.AlignRightCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
                <Button Content="&#xE11C;" FontFamily="Segoe Fluent Icons" ToolTip="上揃え" Command="{Binding DataContext.ActiveDocument.AlignTopCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
                <Button Content="&#xE174;" FontFamily="Segoe Fluent Icons" ToolTip="垂直中央揃え" Command="{Binding DataContext.ActiveDocument.AlignCenterVCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
                <Button Content="&#xE118;" FontFamily="Segoe Fluent Icons" ToolTip="下揃え" Command="{Binding DataContext.ActiveDocument.AlignBottomCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>

                <Border Width="1" Background="#FF555555" Margin="5,2"/>

                <!-- 重ね順 -->
                <Button Content="⏫" ToolTip="最前面へ" Command="{Binding DataContext.ActiveDocument.BringToFrontCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="13"/>
                <Button Content="🔼" ToolTip="前面へ" Command="{Binding DataContext.ActiveDocument.BringForwardCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="13"/>
                <Button Content="🔽" ToolTip="背面へ" Command="{Binding DataContext.ActiveDocument.SendBackwardCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="13"/>
                <Button Content="⏬" ToolTip="最背面へ" Command="{Binding DataContext.ActiveDocument.SendToBackCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="13"/>

                <Border Width="1" Background="#FF555555" Margin="5,2"/>

                <!-- グループ・削除 -->
                <Button Content="&#xE8B3;" FontFamily="Segoe Fluent Icons" ToolTip="グループ化 (Ctrl+G)" Command="{Binding DataContext.ActiveDocument.GroupCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
                <Button Content="&#xE8A9;" FontFamily="Segoe Fluent Icons" ToolTip="グループ解除 (Ctrl+Shift+G)" Command="{Binding DataContext.ActiveDocument.UngroupCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="1" Padding="6,3" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="14"/>
                <Button Content="&#xE74D;" FontFamily="Segoe Fluent Icons" ToolTip="削除 (Del)" Command="{Binding DataContext.ActiveDocument.DeleteSelectedCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="3,1" Padding="6,3" Background="#FF6B2222" Foreground="White" BorderThickness="0" FontSize="13"/>
            </StackPanel>
        </Border>

        <!-- Row 1: 図形ツールバー -->
        <Border Grid.Row="1" Background="#FF252526" BorderBrush="#FF3E3E42" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="5,2">
                <!-- ファイル操作アイコン群 -->
                <Button Content="&#xE7C3;" FontFamily="Segoe Fluent Icons" ToolTip="新規キャンバス (Ctrl+N)" Command="{Binding NewDocumentCommand}" Style="{StaticResource ToolActionButtonStyle}"/>
                <Button Content="&#xE8B7;" FontFamily="Segoe Fluent Icons" ToolTip="開く / インポート (Ctrl+O)" Command="{Binding OpenProjectCommand}" Style="{StaticResource ToolActionButtonStyle}"/>
                <Button Content="&#xE74E;" FontFamily="Segoe Fluent Icons" ToolTip="上書き保存 (Ctrl+S)" Command="{Binding SaveProjectCommand}" Style="{StaticResource ToolActionButtonStyle}"/>
                <Button Content="&#xE792;" FontFamily="Segoe Fluent Icons" ToolTip="別名で保存 (Ctrl+Shift+S)" Command="{Binding SaveAsProjectCommand}" Style="{StaticResource ToolActionButtonStyle}"/>
                <Button Content="&#xEE71;" FontFamily="Segoe Fluent Icons" ToolTip="エクスポート (PNG/PDF/TIF)" Command="{Binding ExportMixedCommand}" Style="{StaticResource ToolActionButtonStyle}"/>

                <!-- セパレータ -->
                <Border Width="1" Background="#FF555555" Margin="8,4"/>

                <RadioButton Content="▢ 選択" Style="{StaticResource ToolButtonStyle}" 
                             IsChecked="{Binding ActiveDocument.CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:DrawingTool.Select}}"/>
                <RadioButton Content="■ 四角形" Style="{StaticResource ToolButtonStyle}" 
                             IsChecked="{Binding ActiveDocument.CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:DrawingTool.Rectangle}}"/>
                <RadioButton Content="● 円" Style="{StaticResource ToolButtonStyle}" 
                             IsChecked="{Binding ActiveDocument.CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:DrawingTool.Ellipse}}"/>
                <RadioButton Content="／ 直線" Style="{StaticResource ToolButtonStyle}" 
                             IsChecked="{Binding ActiveDocument.CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:DrawingTool.Line}}"/>
                <RadioButton Content="T テキスト" Style="{StaticResource ToolButtonStyle}" 
                             IsChecked="{Binding ActiveDocument.CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:DrawingTool.Text}}"/>
                <RadioButton Content="◻ 消しゴム" Style="{StaticResource ToolButtonStyle}" 
                             IsChecked="{Binding ActiveDocument.CurrentTool, Converter={StaticResource EnumToBoolConverter}, ConverterParameter={x:Static vm:DrawingTool.Eraser}}"/>
            </StackPanel>
        </Border>

        <!-- Row 3: メインコンテンツ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/> <!-- 右パネル -->
            </Grid.ColumnDefinitions>

            <TabControl Grid.Column="0" ItemsSource="{Binding Documents}" SelectedItem="{Binding ActiveDocument}" Background="#FF2D2D30" BorderThickness="0">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                            <Button Content="" FontFamily="Segoe MDL2 Assets" Command="{Binding DataContext.FloatDocumentCommand, RelativeSource={RelativeSource AncestorType=TabControl}}" 
                                    CommandParameter="{Binding}"
                                    Margin="10,0,0,0" Background="Transparent" Foreground="Gray" BorderThickness="0" VerticalAlignment="Center" ToolTip="ウィンドウを分離">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#FF007ACC"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="×" Command="{Binding DataContext.CloseDocumentCommand, RelativeSource={RelativeSource AncestorType=TabControl}}" 
                                    CommandParameter="{Binding}"
                                    Margin="10,0,0,0" Background="Transparent" Foreground="Gray" BorderThickness="0" VerticalAlignment="Center">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <views:CanvasView DataContext="{Binding}"/>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

            <!-- 右パネル -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="#FF252526">
            <StackPanel Margin="8">

                <!-- ===== レイヤーパネル ===== -->
                <TextBlock Text="レイヤー" FontWeight="Bold" Margin="0,0,0,8" Foreground="White" FontSize="13"/>
                <Grid Height="150" Margin="0,0,0,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <UniformGrid Columns="4" Margin="0,0,0,4">
                        <Button Content="➕" ToolTip="追加" Command="{Binding ActiveDocument.AddLayerCommand}" Margin="1" Padding="2" Background="#FF007ACC" Foreground="White" BorderThickness="0" FontSize="11"/>
                        <Button Content="🗑" ToolTip="削除" Command="{Binding ActiveDocument.RemoveLayerCommand}" Margin="1" Padding="2" Background="#FF6B2222" Foreground="White" BorderThickness="0" FontSize="11"/>
                        <Button Content="↑" ToolTip="上へ" Command="{Binding ActiveDocument.MoveLayerUpCommand}" Margin="1" Padding="2" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="11"/>
                        <Button Content="↓" ToolTip="下へ" Command="{Binding ActiveDocument.MoveLayerDownCommand}" Margin="1" Padding="2" Background="#FF3E3E42" Foreground="White" BorderThickness="0" FontSize="11"/>
                    </UniformGrid>
                    <ListBox Grid.Row="1" ItemsSource="{Binding ActiveDocument.Layers}" SelectedItem="{Binding ActiveDocument.ActiveLayer, Mode=TwoWay}" Background="#FF3E3E42" BorderThickness="0" Foreground="White">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.ContextMenu>
                                        <ContextMenu><MenuItem Header="選択オブジェクトをこのレイヤーに移動" Command="{Binding DataContext.ActiveDocument.MoveObjectToLayerCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/></ContextMenu>
                                    </Grid.ContextMenu>
                                    <ToggleButton Grid.Column="0" IsChecked="{Binding IsVisible}" Margin="0,0,3,0" Width="18" Height="18" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" ToolTip="表示/非表示">
                                        <ToggleButton.Style><Style TargetType="ToggleButton"><Setter Property="Content" Value="👁"/><Setter Property="Foreground" Value="White"/><Style.Triggers><Trigger Property="IsChecked" Value="False"><Setter Property="Content" Value="ー"/><Setter Property="Foreground" Value="Gray"/></Trigger></Style.Triggers></Style></ToggleButton.Style>
                                    </ToggleButton>
                                    <ToggleButton Grid.Column="1" IsChecked="{Binding IsLocked}" Margin="0,0,3,0" Width="18" Height="18" Background="Transparent" BorderThickness="0" VerticalAlignment="Center" ToolTip="ロック">
                                        <ToggleButton.Style><Style TargetType="ToggleButton"><Setter Property="Content" Value="🔓"/><Setter Property="Foreground" Value="White"/><Style.Triggers><Trigger Property="IsChecked" Value="True"><Setter Property="Content" Value="🔒"/><Setter Property="Foreground" Value="Gray"/></Trigger></Style.Triggers></Style></ToggleButton.Style>
                                    </ToggleButton>
                                    <TextBox Grid.Column="2" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Background="Transparent" Foreground="White" BorderThickness="0" VerticalAlignment="Center" Padding="2" FontSize="11"/>
                                    <Button Grid.Column="3" Content="📥" FontSize="9" Width="20" Height="20" Background="Transparent" Foreground="White" BorderThickness="0" ToolTip="移動" Command="{Binding DataContext.ActiveDocument.MoveObjectToLayerCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
                <Separator Margin="0,8" Background="#FF3E3E42"/>
                <TextBlock Text="アートボード" FontWeight="Bold" Margin="0,0,0,6" Foreground="White" FontSize="13"/>
                <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="名前:" Foreground="Gray" VerticalAlignment="Center" FontSize="11"/>
                    <TextBox Grid.Column="1" Text="{Binding ActiveDocument.Title, UpdateSourceTrigger=PropertyChanged}" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="4,2" FontSize="11"/>
                </Grid>
                <Grid Margin="0,3"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="サイズ:" Foreground="Gray" VerticalAlignment="Center" FontSize="11"/>
                    <TextBox Grid.Column="1" Text="{Binding ActiveDocument.WidthMm, UpdateSourceTrigger=PropertyChanged, Delay=500}" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="4,2" FontSize="11" ToolTip="幅 (mm)"/>
                    <TextBlock Grid.Column="2" Text="×" Foreground="Gray" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="11"/>
                    <TextBox Grid.Column="3" Text="{Binding ActiveDocument.HeightMm, UpdateSourceTrigger=PropertyChanged, Delay=500}" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="4,2" FontSize="11" ToolTip="高さ (mm)"/>
                </Grid>
                <Separator Margin="0,8" Background="#FF3E3E42"/>
                <StackPanel DataContext="{Binding ActiveDocument.SelectedObject}">
                    <TextBlock Text="線" FontWeight="Bold" Margin="0,0,0,6" Foreground="White" FontSize="13"/>
                    <Grid Margin="0,2"><Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <TextBlock Text="太さ:" Foreground="Gray" VerticalAlignment="Center" FontSize="11"/>
                        <TextBox Grid.Column="1" Text="{Binding StrokeWidth, StringFormat=\{0:F1\}, UpdateSourceTrigger=PropertyChanged}" Background="#FF3E3E42" Foreground="White" BorderThickness="0" Padding="4,2" FontSize="11"/>
                    </Grid>
                    <TextBlock Text="枠線色:" Margin="0,6,0,4" Foreground="Gray" FontSize="11"/>
                    <UniformGrid Columns="7" Margin="0,0,0,1">
                        <Button Background="Black" Height="18" Margin="1" BorderThickness="1" BorderBrush="#FF555555" Command="{Binding DataContext.ChangeStrokeColorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Black"/>
                        <Button Background="White" Height="18" Margin="1" BorderThickness="0" Command="{Binding DataContext.ChangeStrokeColorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="White"/>
                        <Button Background="#FFFF0000" Height="18" Margin="1" BorderThickness="0" Command="{Binding DataContext.ChangeStrokeColorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Red"/>
                        <Button Background="#FFFFA500" Height="18" Margin="1" BorderThickness="0" Command="{Binding DataContext.ChangeStrokeColorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Orange"/>
                        <Button Background="#FFFFFF00" Height="18" Margin="1" BorderThickness="0" Command="{Binding DataContext.ChangeStrokeColorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Yellow"/>
                        <Button Background="#FF008000" Height="18" Margin="1" BorderThickness="0" Command="{Binding DataContext.ChangeStrokeColorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="Green"/>
